diff --git a/.env.example b/.env.example
new file mode 100644
index 0000000..1aad9de
--- /dev/null
+++ b/.env.example
@@ -0,0 +1,10 @@
+# Example environment variables for local development.
+#
+# IMPORTANT GUARDRAIL:
+# - Do NOT commit a real `.env` file.
+# - Do NOT write code that reads/parses `.env` from disk.
+# - Copy this file to `.env` locally if you need secrets.
+
+# Optional: GitHub Personal Access Token (fine-grained, read-only for public repos is sufficient)
+# Used at build time to increase rate limits when fetching README content.
+GITHUB_TOKEN=
