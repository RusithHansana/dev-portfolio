---
import { siteConfig } from "../config";
import ThemeToggle from "./ThemeToggle.astro";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 block w-full transition-all duration-300 border-b border-transparent"
>
  <nav class="max-w-7xl mx-auto px-4 md:px-8 py-4 flex items-center justify-between relative">
    <!-- Desktop: ThemeToggle on the left -->
    <div class="hidden md:block">
      <ThemeToggle />
    </div>

    <!-- Desktop Navigation (Centered) -->
    <ul class="hidden md:flex items-center gap-8 justify-center flex-1">
      <li>
        <a
          href="#about"
          class="text-zinc-700 dark:text-zinc-300 hover:text-black dark:hover:text-white transition-colors font-medium"
        >
          About
        </a>
      </li>
      {
        hasProjects && (
          <li>
            <a
              href="#projects"
              class="text-zinc-700 dark:text-zinc-300 hover:text-black dark:hover:text-white transition-colors font-medium"
            >
              Projects
            </a>
          </li>
        )
      }
      {
        hasExperience && (
          <li>
            <a
              href="#experience"
              class="text-zinc-700 dark:text-zinc-300 hover:text-black dark:hover:text-white transition-colors font-medium"
            >
              Experience
            </a>
          </li>
        )
      }
      {
        hasEducation && (
          <li>
            <a
              href="#education"
              class="text-zinc-700 dark:text-zinc-300 hover:text-black dark:hover:text-white transition-colors font-medium"
            >
              Education
            </a>
          </li>
        )
      }
    </ul>

    <!-- Mobile Navigation Bar -->
    <div class="flex md:hidden items-center justify-between w-full">
      <ThemeToggle />
      <button
        id="mobile-menu-button"
        type="button"
        class="text-zinc-700 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-800 p-2 rounded-lg transition-colors"
        aria-label="Toggle mobile menu"
      >
        <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu Overlay -->
    <div
      id="mobile-menu"
      class="fixed inset-0 top-[72px] bg-zinc-50/98 dark:bg-zinc-950/98 backdrop-blur-xl z-40 hidden flex-col p-8 transition-all duration-300"
    >
      <ul class="flex flex-col gap-6 text-center mt-12">
        <li>
          <a
            href="#about"
            class="mobile-link text-2xl font-bold text-zinc-800 dark:text-zinc-100"
          >
            About
          </a>
        </li>
        {
          hasProjects && (
            <li>
              <a
                href="#projects"
                class="mobile-link text-2xl font-bold text-zinc-800 dark:text-zinc-100"
              >
                Projects
              </a>
            </li>
          )
        }
        {
          hasExperience && (
            <li>
              <a
                href="#experience"
                class="mobile-link text-2xl font-bold text-zinc-800 dark:text-zinc-100"
              >
                Experience
              </a>
            </li>
          )
        }
        {
          hasEducation && (
            <li>
              <a
                href="#education"
                class="mobile-link text-2xl font-bold text-zinc-800 dark:text-zinc-100"
              >
                Education
              </a>
            </li>
          )
        }
      </ul>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById("header");
  const mobileMenuButton = document.getElementById("mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const hamburgerIcon = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");
  const mobileLinks = document.querySelectorAll(".mobile-link");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 100) {
      header?.classList.add("bg-white/80", "dark:bg-zinc-950/80", "backdrop-blur-sm", "border-zinc-200", "dark:border-zinc-800");
    } else {
      header?.classList.remove("bg-white/80", "dark:bg-zinc-950/80", "backdrop-blur-sm", "border-zinc-200", "dark:border-zinc-800");
    }
  });

  const toggleMenu = () => {
    mobileMenu?.classList.toggle("hidden");
    mobileMenu?.classList.toggle("flex");
    hamburgerIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
    document.body.classList.toggle("overflow-hidden");
  };

  mobileMenuButton?.addEventListener("click", toggleMenu);

  mobileLinks.forEach(link => {
    link.addEventListener("click", () => {
      toggleMenu();
    });
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
