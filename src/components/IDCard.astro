---
import '../styles/IDCard.css';

export interface Props {
  name: string;
  role: string;
  avatar: string;
  stack: string;
  location: string;
  status: string;
}

const { name, role, avatar, stack, location, status } = Astro.props;

const isAvailable = status === 'Available' || status.toLowerCase().includes('available') || status.toLowerCase().includes('open');
---

<div class="id-card-anchor">
  <div class="id-card-assembly">
    <div class="id-card-nail"></div>
    <div class="id-card-string"></div>
    <div class="id-card-body">
      <div class="id-card-accent-stripe"></div>
      
      <img src={avatar} alt={`${name} avatar`} class="id-card-avatar" />
      <h3 class="id-card-name">{name}</h3>
      <span class="id-card-role">{role}</span>
      
      <div class="id-card-divider"></div>
      
      <dl class="id-card-grid">
        <dt>Stack</dt>
        <dd>{stack}</dd>
        
        <dt>Location</dt>
        <dd>{location}</dd>
        
        <dt>Status</dt>
        <dd>
          {isAvailable && <span class="id-card-status-dot"></span>}
          {status}
        </dd>
      </dl>
    </div>
  </div>
</div>

<script>
  import { hasGPU } from '../utils/gpu';

  function initInteractiveCard() {
    const isGPUAvailable = hasGPU();
    const hero = document.getElementById('hero');
    const assembly = document.querySelector('.id-card-assembly') as HTMLElement | null;
    
    if (!assembly) return;

    if (!isGPUAvailable) {
      assembly.classList.add('swing-mode');
      return;
    }

    if (!hero) return;

    // Apply hardware acceleration since GPU is available
    assembly.style.willChange = 'transform';

    const MAX_ANGLE = 20;
    const LERP_SPEED = 0.08;
    
    let currentAngle = 0;
    let targetAngle = 0;
    let rafId: number | null = null;

    const animate = () => {
      const diff = targetAngle - currentAngle;
      currentAngle += diff * LERP_SPEED;
      
      assembly.style.transform = `rotate(${currentAngle.toFixed(3)}deg)`;
      
      if (Math.abs(diff) > 0.05) {
        rafId = requestAnimationFrame(animate);
      } else {
        currentAngle = targetAngle;
        assembly.style.transform = `rotate(${targetAngle.toFixed(3)}deg)`;
        rafId = null;
      }
    };

    const setTarget = (angle: number) => {
      targetAngle = angle;
      if (!rafId) {
        rafId = requestAnimationFrame(animate);
      }
    };

    const onMove = (e: MouseEvent) => {
      const rect = hero.getBoundingClientRect();
      const ratio = ((e.clientX - rect.left) / rect.width) * 2 - 1;
      setTarget(ratio * MAX_ANGLE);
    };

    const onLeave = () => {
      setTarget(0);
    };

    hero.addEventListener('mousemove', onMove);
    hero.addEventListener('mouseleave', onLeave);
  }

  // Run on initial load
  initInteractiveCard();
  // Support Astro View Transitions if enabled
  document.addEventListener('astro:page-load', initInteractiveCard);
</script>
